{
  "$schema": "https://opencode.ai/config.json",
  "model": "nim/moonshotai/kimi-k2.6",
  "small_model": "nim/meta/llama-3.1-8b-instruct",
  "provider": {
    "nim": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "NVIDIA NIM",
      "options": {
        "baseURL": "http://127.0.0.1:8123/v1",
        "apiKey": "{env:NVIDIA_API_KEY}"
      },
      "models": {
        "moonshotai/kimi-k2.6": {
          "name": "Kimi K2.6 1T MoE (NIM) — default, fastest + clean tool-calls",
          "tool_call": true,
          "limit": { "context": 128000, "output": 8192 }
        },
        "qwen/qwen3-coder-480b-a35b-instruct": {
          "name": "Qwen3 Coder 480B MoE (NIM) — best code, infra-flaky",
          "tool_call": true,
          "limit": { "context": 128000, "output": 8192 }
        },
        "qwen/qwen3.5-122b-a10b": {
          "name": "Qwen3.5 122B MoE (NIM)",
          "tool_call": true,
          "limit": { "context": 128000, "output": 8192 }
        },
        "nvidia/nemotron-3-super-120b-a12b": {
          "name": "Nemotron-3 Super 120B MoE (NIM) — Mamba-Transformer, 1M ctx",
          "tool_call": true,
          "limit": { "context": 200000, "output": 8192 }
        },
        "meta/llama-3.3-70b-instruct": {
          "name": "Llama 3.3 70B Instruct (NIM) — stable fallback",
          "tool_call": true,
          "limit": { "context": 128000, "output": 8192 }
        },
        "meta/llama-3.1-8b-instruct": {
          "name": "Llama 3.1 8B Instruct (NIM) — small/fast for auxiliary calls",
          "tool_call": true,
          "limit": { "context": 128000, "output": 8192 }
        }
      }
    }
  }
}
